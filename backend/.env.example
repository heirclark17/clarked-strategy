# Copy to .env for local dev, or set these as variables in Railway.
# Every integration is optional — leave a key blank and that feature stays off.

# --- Core ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,https://clarkedstrategy.com,https://www.clarkedstrategy.com

# --- Database ---
# Railway injects DATABASE_URL automatically when you add a Postgres plugin.
# Local default (if unset) is a SQLite file: sqlite:///./clarked.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Auth ---
# REQUIRED in production. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me

# --- Email (Resend) ---  https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=derrick88clark@yahoo.com
# Use onboarding@resend.dev until you verify clarkedstrategy.com in Resend.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# --- Payments (Stripe) ---  https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=https://clarkedstrategy.com/success
CHECKOUT_CANCEL_URL=https://clarkedstrategy.com/pricing

# --- AI (Anthropic) ---  https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
